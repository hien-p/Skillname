{
  "$schema": "https://manifest.eth/schemas/skill-v1.json",
  "name": "swap-uniswap",
  "ensName": "swap.uniswap.eth",
  "version": "1.0.0",
  "description": "One function: transfer USDC on Base Sepolia through KeeperHub. Pay-per-call ($0.05 USDC) via x402.",
  "author": "0x0000000000000000000000000000000000000000",
  "createdAt": "2026-04-28T00:00:00Z",
  "license": "MIT",
  "tools": [
    {
      "name": "execute_swap",
      "description": "Transfers USDC on Base Sepolia via KeeperHub. Pay $0.05 USDC per call through x402. Returns the BaseScan tx hash.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "to": {
            "type": "string",
            "pattern": "^0x[a-fA-F0-9]{40}$",
            "description": "Recipient wallet address"
          },
          "amount": {
            "type": "string",
            "description": "Amount of USDC to transfer (e.g. 0.01)"
          },
          "token": {
            "type": "string",
            "default": "USDC",
            "description": "Token symbol (default: USDC)"
          }
        },
        "required": [
          "to",
          "amount"
        ]
      },
      "execution": {
        "type": "keeperhub",
        "tool": "execute_transfer",
        "chainId": 84532,
        "payment": {
          "protocol": "x402",
          "price": "$0.05",
          "token": "USDC",
          "network": "base-sepolia"
        }
      }
    }
  ],
  "trust": {
    "ensip25": {
      "enabled": true
    },
    "erc8004": {
      "registry": "eip155:11155111:0x48f77FfE1f02FB94bDe9c8ffe84bB4956ace11e4",
      "agentId": 8
    }
  }
}
